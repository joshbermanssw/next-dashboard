# Session encryption key — generate with: openssl rand -base64 32
SESSION_SECRET=

# Backend auth microservice
MS_AUTH_BASE_URL=

# Backend API microservice (future)
MS_API_BASE_URL=

# Assets API — public plan catalogue (optional; defaults to the dev host)
MS_ASSETS_BASE_URL=

# Dev-only: set to 1 to stub the sign-up flow (skip real OTP/provisioning and
# accept any 6-digit code) while the backend send is down. Ignored in production.
SIGNUP_DEV_STUB=

